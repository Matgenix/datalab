# Development template: copy to `webapp/.env` (gitignored) and edit as desired.
# Full list of options: https://docs.datalab-org.io/en/latest/config/

VUE_APP_WEBSITE_TITLE=datalab (dev)
VUE_APP_EDITABLE_INVENTORY=true
VUE_APP_AUTOMATICALLY_GENERATE_ID_DEFAULT=false

# Everything below is optional; defaults shown where set.
# VUE_APP_API_URL=http://localhost:5001    # already set by the Docker dev stack
# VUE_APP_LOGO_URL=
# VUE_APP_LOGO_WIDTH=100
# VUE_APP_HOMEPAGE_URL=
# VUE_APP_QR_CODE_RESOLVER_URL=
# VUE_APP_UPPY_MAX_NUMBER_OF_FILES=10000
# VUE_APP_UPPY_MAX_TOTAL_FILE_SIZE=102400000000
# VUE_APP_GIT_VERSION=                     # set automatically at build time
